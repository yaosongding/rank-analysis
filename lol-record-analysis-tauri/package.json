{
  "name": "lol-record-analysis-app",
  "private": true,
  "description": "lol record analysis app",
  "type": "module",
  "author": "wnzzer",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck": "vue-tsc --noEmit --composite false",
    "check": "npm run format && npm run lint && npm run typecheck && npm run check:rust",
    "check:rust": "cd src-tauri && cargo fmt --all -- --check && cargo clippy --all-targets --all-features -- -Dwarnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.4.4",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.3.1",
    "vue": "^3.4.15",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@tauri-apps/cli": "^2.10.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.16",
    "@vicons/ionicons5": "^0.12.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitest/coverage-v8": "^1.2.2",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.21.1",
    "jsdom": "^24.0.0",
    "naive-ui": "^2.37.3",
    "prettier": "^3.2.5",
    "terser": "^5.39.0",
    "typescript": "5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2",
    "vue-tsc": "^2.2.8"
  }
}
